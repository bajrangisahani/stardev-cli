{
  "name": "stardev-cli",
  "version": "1.0.0",
  "description": "A production-ready developer productivity CLI for project setup, GitHub publishing, deployment, documentation, reviews, releases, screenshots, and client assets.",
  "type": "module",
  "bin": {
    "stardev": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "github",
    "deployment",
    "readme",
    "automation",
    "typescript"
  ],
  "author": "STARDEV CLI Contributors",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "env-paths": "^3.0.0",
    "fs-extra": "^11.2.0",
    "gif-encoder-2": "^1.0.5",
    "gradient-string": "^3.0.0",
    "inquirer": "^12.3.0",
    "ora": "^8.1.1",
    "open": "^10.1.0",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "sharp": "^0.33.5",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
